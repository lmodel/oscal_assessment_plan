oscal_assessment_plan:include_controls a owl:ObjectProperty ;
    rdfs:label "include-controls" ;
    rdfs:range oscal_assessment_plan:AssessmentSelectControlById ;
    skos:definition "Controls to include in the assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:include_objectives a owl:ObjectProperty ;
    rdfs:label "include-objectives" ;
    rdfs:range oscal_assessment_plan:SelectObjectiveById ;
    skos:definition "Objectives to include in the assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:include_subjects a owl:ObjectProperty ;
    rdfs:label "include-subjects" ;
    rdfs:range oscal_assessment_plan:SelectSubjectById ;
