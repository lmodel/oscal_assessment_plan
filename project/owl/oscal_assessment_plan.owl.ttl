oscal_assessment_plan:methods a owl:ObjectProperty ;
    rdfs:label "methods" ;
    rdfs:range oscal_assessment_plan:ObservationMethodEnum ;
    skos:definition "Identifies how the observation was made." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:mitigating_factors a owl:ObjectProperty ;
    rdfs:label "mitigating-factors" ;
    rdfs:range oscal_assessment_plan:MitigatingFactor ;
