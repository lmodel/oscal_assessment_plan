    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:rel a owl:DatatypeProperty ;
    rdfs:label "rel" ;
    rdfs:range xsd:string ;
    skos:definition "Describes the type of relationship provided by the link's hypertext reference. This can be an indicator of the link's purpose." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:resource_fragment a owl:DatatypeProperty ;
    rdfs:label "resource-fragment" ;
    rdfs:range xsd:string ;
    skos:definition "In case where the href points to a back-matter/resource, this value will indicate the URI fragment to append to any rlink associated with the resource. This value MUST be URI encoded." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:select a owl:ObjectProperty ;
    rdfs:label "select" ;
    rdfs:range oscal_catalog:ParameterSelection ;
    skos:definition "Presenting a choice among alternatives." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:usage a owl:DatatypeProperty ;
    rdfs:label "usage" ;
    rdfs:range xsd:string ;
    skos:definition "Describes the purpose and use of a parameter." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:with_child_controls a owl:ObjectProperty ;
    rdfs:label "with-child-controls" ;
    rdfs:range oscal_assessment_plan:WithChildControlsEnum ;
    skos:definition "When a control is included, whether its child (dependent) controls are also included." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_assessment_plan:AssessmentPart a owl:Class ;
