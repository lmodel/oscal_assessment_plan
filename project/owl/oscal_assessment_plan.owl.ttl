    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:logged_by a owl:ObjectProperty ;
    rdfs:label "logged-by" ;
    rdfs:range oscal_assessment_plan:LoggedBy ;
