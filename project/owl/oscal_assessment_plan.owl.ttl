    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:objectives_and_methods a owl:ObjectProperty ;
    rdfs:label "objectives-and-methods" ;
    rdfs:range oscal_assessment_plan:LocalObjective ;
