    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:import_ssp a owl:ObjectProperty ;
    rdfs:label "import-ssp" ;
    rdfs:range oscal_assessment_plan:ImportSSP ;
    skos:definition "Used to import information about the system from an SSP." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:lifecycle a owl:ObjectProperty ;
    rdfs:label "lifecycle" ;
    rdfs:range oscal_assessment_plan:ResponseLifecycleEnum ;
