oscal_catalog:guidelines a owl:ObjectProperty ;
    rdfs:label "guidelines" ;
    rdfs:range oscal_catalog:ParameterGuideline ;
    skos:definition "A prose statement that provides a recommendation for the use of a parameter." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:hashes a owl:ObjectProperty ;
    rdfs:label "hashes" ;
    rdfs:range oscal_catalog:Hash ;
    skos:definition "A representation of a cryptographic digest generated over a resource using a specified hash algorithm." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:links a owl:ObjectProperty ;
    rdfs:label "links" ;
    rdfs:range oscal_catalog:Link ;
    skos:definition "A list of links." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:location_uuids a owl:DatatypeProperty ;
    rdfs:label "location-uuids" ;
    rdfs:range xsd:string ;
    skos:definition "Reference to a location by UUID." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:locations a owl:ObjectProperty ;
    rdfs:label "locations" ;
    rdfs:range oscal_catalog:Location ;
    skos:definition "A physical point of presence, which may be associated with people, organizations, or other concepts within the current or linked OSCAL document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:matching a owl:ObjectProperty ;
