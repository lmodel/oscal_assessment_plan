oscal_assessment_plan:expires a owl:DatatypeProperty ;
    rdfs:label "expires" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date/time identifying when the finding information is no longer considered valid." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:identified_subject a owl:ObjectProperty ;
    rdfs:label "identified-subject" ;
    rdfs:range oscal_assessment_plan:IdentifiedSubject ;
    skos:definition "Used to detail assessment subjects that were identified by this task." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:identifier_type a owl:DatatypeProperty ;
    rdfs:label "identifier-type" ;
    rdfs:range xsd:anyURI ;
    skos:definition "A human-readable label for a specific identifier scheme." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:implementation_statement_uuid a owl:DatatypeProperty ;
    rdfs:label "implementation-statement-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to the implementation statement in the SSP to which this finding is related." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:implementation_status a owl:ObjectProperty ;
    rdfs:label "implementation-status" ;
    rdfs:range oscal_assessment_plan:ImplementationStatus ;
