oscal_catalog:base64 a owl:ObjectProperty ;
    rdfs:label "base64" ;
    rdfs:range oscal_catalog:Base64Resource ;
    skos:definition "A resource encoded using the Base64 alphabet defined by RFC 2045." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:catalog a owl:ObjectProperty ;
    rdfs:label "catalog" ;
    rdfs:range oscal_catalog:Catalog ;
    skos:definition "Root catalog document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:citation a owl:ObjectProperty ;
    rdfs:label "citation" ;
    rdfs:range oscal_catalog:Citation ;
    skos:definition "An optional citation consisting of end note text using structured markup." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:city a owl:DatatypeProperty ;
    rdfs:label "city" ;
    rdfs:range xsd:string ;
