    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:local_definitions a owl:ObjectProperty ;
    rdfs:label "local-definitions" ;
    rdfs:range oscal_assessment_plan:LocalDefinitions ;
    skos:definition "Used to define data objects that do not appear in the referenced SSP." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:objective_id a owl:DatatypeProperty ;
    rdfs:label "objective-id" ;
    rdfs:range xsd:string ;
    skos:definition "Reference to a control objective by its identifier." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:observation_uuid a owl:DatatypeProperty ;
    rdfs:label "observation-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to an observation defined in the list of observations." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:on_date a owl:ObjectProperty ;
    rdfs:label "on-date" ;
    rdfs:range oscal_assessment_plan:OnDateCondition ;
    skos:definition "The task is intended to occur on the specified date." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:origin a owl:ObjectProperty ;
    rdfs:label "origin" ;
    rdfs:range oscal_assessment_plan:Origin ;
    skos:definition "The source of the finding." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:param_id a owl:DatatypeProperty ;
    rdfs:label "param-id" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to a parameter by its identifier." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:part a owl:ObjectProperty ;
    rdfs:label "part" ;
    rdfs:range oscal_assessment_plan:AssessmentPart ;
    skos:definition "An assessment part." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:party_uuid a owl:DatatypeProperty ;
    rdfs:label "party-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to the party who is making the log entry." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:period a owl:DatatypeProperty ;
    rdfs:label "period" ;
    rdfs:range xsd:integer ;
    skos:definition "The task must occur every period (in the given units)." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:purpose a owl:DatatypeProperty ;
    rdfs:label "purpose" ;
    rdfs:range xsd:string ;
    skos:definition "A summary of the technological or business purpose of the component." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:reason a owl:ObjectProperty ;
    rdfs:label "reason" ;
    rdfs:range oscal_assessment_plan:ObjectiveStatusReasonEnum ;
    skos:definition "The reason the objective was given its status." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:related_controls a owl:ObjectProperty ;
    rdfs:label "related-controls" ;
    rdfs:range oscal_assessment_plan:ReviewedControls ;
    skos:definition "A reference to reviewed controls for this activity or step." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:response_uuid a owl:DatatypeProperty ;
    rdfs:label "response-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to a unique risk response." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:risk_log a owl:ObjectProperty ;
    rdfs:label "risk-log" ;
    rdfs:range oscal_assessment_plan:RiskLog ;
    skos:definition "A log of all risk-related tasks taken." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:risk_uuid a owl:DatatypeProperty ;
    rdfs:label "risk-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to a risk defined in the list of risks." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:statement a owl:DatatypeProperty ;
    rdfs:label "statement" ;
    rdfs:range xsd:string ;
    skos:definition "An assessor's summary of the risk, in narrative form." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:status_change a owl:ObjectProperty ;
    rdfs:label "status-change" ;
    rdfs:range oscal_assessment_plan:RiskStatusEnum ;
    skos:definition "Identifies the risk change that prompted the log entry." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:subject_placeholder_uuid a owl:DatatypeProperty ;
    rdfs:label "subject-placeholder-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A reference to an assessment subject placeholder defined in the assessment plan." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:target a owl:ObjectProperty ;
    rdfs:label "target" ;
    rdfs:range oscal_assessment_plan:FindingTarget ;
    skos:definition "Identifies the target of a finding." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:target_id a owl:DatatypeProperty ;
    rdfs:label "target-id" ;
    rdfs:range xsd:string ;
    skos:definition "Identifies the specific target qualified by the type." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:terms_and_conditions a owl:ObjectProperty ;
    rdfs:label "terms-and-conditions" ;
    rdfs:range oscal_assessment_plan:TermsAndConditions ;
    skos:definition "Terms and conditions under which an assessment can be performed." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:timing a owl:ObjectProperty ;
    rdfs:label "timing" ;
    rdfs:range oscal_assessment_plan:EventTiming ;
    skos:definition "The timing under which a task is intended to occur." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:transport a owl:ObjectProperty ;
    rdfs:label "transport" ;
    rdfs:range oscal_assessment_plan:TransportEnum ;
    skos:definition "Indicates the transport type." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:unit a owl:ObjectProperty ;
    rdfs:label "unit" ;
    rdfs:range oscal_assessment_plan:TimingUnitEnum ;
    skos:definition "The unit of time for the period." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:within_date_range a owl:ObjectProperty ;
    rdfs:label "within-date-range" ;
    rdfs:range oscal_assessment_plan:WithinDateRange ;
    skos:definition "The task is intended to occur within the specified date range." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_catalog:BackMatter a owl:Class ;
    rdfs:label "BackMatter" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Resource ;
            owl:onProperty oscal_catalog:resources ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:resources ] ;
    skos:definition "A collection of resources that may be referenced from within the OSCAL document instance." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:DocumentId a owl:Class ;
    rdfs:label "DocumentId" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:identifier ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:identifier ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty oscal_catalog:scheme ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:identifier ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:scheme ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:scheme ] ;
    skos:definition "A document identifier qualified by an identifier scheme." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:Group a owl:Class ;
    rdfs:label "Group" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Part ;
            owl:onProperty oscal_catalog:parts ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Parameter ;
            owl:onProperty oscal_catalog:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Control ;
            owl:onProperty oscal_catalog:controls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:_class ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Group ;
            owl:onProperty oscal_catalog:groups ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:groups ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:_class ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:_class ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:params ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:parts ],
        oscal_catalog:OscalCommon ;
    skos:definition "A group of controls, or of groups of controls." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

