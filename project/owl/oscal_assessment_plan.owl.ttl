    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:protocols a owl:ObjectProperty ;
    rdfs:label "protocols" ;
    rdfs:range oscal_assessment_plan:Protocol ;
    skos:definition "Information about the protocol used to provide a service." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:related_responses a owl:ObjectProperty ;
    rdfs:label "related-responses" ;
    rdfs:range oscal_assessment_plan:RiskResponseReference ;
    skos:definition "Identifies an individual risk response that this log entry is for." ;
