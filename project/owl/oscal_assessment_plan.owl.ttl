oscal_catalog:how_many a owl:ObjectProperty ;
    rdfs:label "how-many" ;
    rdfs:range oscal_assessment_plan:ParameterCardinalityEnum ;
    skos:altLabel "how_many" ;
    skos:definition "Describes the number of selections that must occur. Without this setting, only one value should be assumed to be permitted." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:identifier a owl:DatatypeProperty ;
    rdfs:label "identifier" ;
    rdfs:range xsd:string ;
