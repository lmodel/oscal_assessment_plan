oscal_assessment_plan:types a owl:ObjectProperty ;
    rdfs:label "types" ;
    rdfs:range oscal_assessment_plan:ObservationTypeEnum ;
    skos:definition "Identifies the nature of the observation." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:users a owl:ObjectProperty ;
    rdfs:label "users" ;
    rdfs:range oscal_assessment_plan:SystemUser ;
    skos:definition "A collection of system users." ;
