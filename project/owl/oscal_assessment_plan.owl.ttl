<https://w3id.org/lmodel/oscal_assessment_plan/TransportEnum#TCP> a owl:Class ;
    rdfs:label "TCP" ;
    rdfs:subClassOf oscal_assessment_plan:TransportEnum .

<https://w3id.org/lmodel/oscal_assessment_plan/TransportEnum#UDP> a owl:Class ;
    rdfs:label "UDP" ;
    rdfs:subClassOf oscal_assessment_plan:TransportEnum .

oscal_assessment_plan:UsesComponent a owl:Class ;
    rdfs:label "UsesComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:component_uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:component_uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:component_uuid ],
        oscal_catalog:HasResponsibleParties,
        oscal_catalog:OscalCommon ;
    skos:definition "The set of components that are used by the assessment platform." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/WithChildControlsEnum#False> a owl:Class ;
    rdfs:label "False" ;
    rdfs:subClassOf oscal_assessment_plan:WithChildControlsEnum .

<https://w3id.org/lmodel/oscal_assessment_plan/WithChildControlsEnum#True> a owl:Class ;
    rdfs:label "True" ;
    rdfs:subClassOf oscal_assessment_plan:WithChildControlsEnum .

oscal_assessment_plan:WithinDateRange a owl:Class ;
    rdfs:label "WithinDateRange" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:end ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty oscal_assessment_plan:end ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:end ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty oscal_assessment_plan:start ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:start ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:start ] ;
    skos:definition "The task is intended to occur within the specified date range." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:activities a owl:ObjectProperty ;
    rdfs:label "activities" ;
    rdfs:range oscal_assessment_plan:Activity ;
