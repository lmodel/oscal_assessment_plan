        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:type ] ;
    skos:definition "A telephone service number as defined by ITU-T E.164." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:address a owl:ObjectProperty ;
    rdfs:label "address" ;
    rdfs:range oscal_catalog:Address ;
    skos:definition "A postal address for the location." ;
