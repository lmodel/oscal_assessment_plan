oscal_catalog:addresses a owl:ObjectProperty ;
    rdfs:label "addresses" ;
    rdfs:range oscal_catalog:Address ;
    skos:definition "Postal addresses associated with the containing object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:choice a owl:DatatypeProperty ;
    rdfs:label "choice" ;
    rdfs:range xsd:string ;
    skos:definition "A value selection among several such options." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:constraints a owl:ObjectProperty ;
    rdfs:label "constraints" ;
    rdfs:range oscal_catalog:ParameterConstraint ;
    skos:definition "A formal or informal expression of a constraint or test." ;
