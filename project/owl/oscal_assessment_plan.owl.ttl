    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:port_ranges a owl:ObjectProperty ;
    rdfs:label "port-ranges" ;
    rdfs:range oscal_assessment_plan:PortRange ;
