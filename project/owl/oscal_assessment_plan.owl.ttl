    rdfs:label "id" ;
    rdfs:range xsd:string ;
    skos:definition "A unique human-oriented identifier within a particular context." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:type a owl:DatatypeProperty ;
    rdfs:label "type" ;
    rdfs:range xsd:string ;
    skos:definition "Indicates the nature or kind of the containing object." ;
