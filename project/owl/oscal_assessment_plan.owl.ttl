oscal_assessment_plan:related_risks a owl:ObjectProperty ;
    rdfs:label "related-risks" ;
    rdfs:range oscal_assessment_plan:AssociatedRisk ;
    skos:definition "Relates the finding to a set of referenced risks." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:relevant_evidence a owl:ObjectProperty ;
    rdfs:label "relevant-evidence" ;
    rdfs:range oscal_assessment_plan:RelevantEvidence ;
    skos:definition "Links the observation to relevant evidence." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:remediations a owl:ObjectProperty ;
    rdfs:label "remediations" ;
    rdfs:range oscal_assessment_plan:Response ;
    skos:definition "Describes either recommended or actual responses to a risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:required_assets a owl:ObjectProperty ;
    rdfs:label "required-assets" ;
    rdfs:range oscal_assessment_plan:RequiredAsset ;
