    rdfs:range xsd:anyURI ;
    skos:definition "The uniform resource locator (URL) for a web site or other resource associated with the location." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:with_ids a owl:DatatypeProperty ;
    rdfs:label "with-ids" ;
    rdfs:range xsd:string ;
    skos:definition "Selecting a control by its ID given as a literal." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_assessment_plan:AddressTypeEnum a owl:Class ;
    rdfs:label "AddressTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/oscal_assessment_plan/AddressTypeEnum#home> <https://w3id.org/lmodel/oscal_assessment_plan/AddressTypeEnum#work> ) ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> ;
    linkml:permissible_values <https://w3id.org/lmodel/oscal_assessment_plan/AddressTypeEnum#home>,
        <https://w3id.org/lmodel/oscal_assessment_plan/AddressTypeEnum#work> .

oscal_assessment_plan:FindingTargetTypeEnum a owl:Class ;
    rdfs:label "FindingTargetTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/oscal_assessment_plan/FindingTargetTypeEnum#statement-id> <https://w3id.org/lmodel/oscal_assessment_plan/FindingTargetTypeEnum#objective-id> ) ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> ;
    linkml:permissible_values <https://w3id.org/lmodel/oscal_assessment_plan/FindingTargetTypeEnum#objective-id>,
        <https://w3id.org/lmodel/oscal_assessment_plan/FindingTargetTypeEnum#statement-id> .

oscal_assessment_plan:ObjectiveStatusStateEnum a owl:Class ;
    rdfs:label "ObjectiveStatusStateEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/oscal_assessment_plan/ObjectiveStatusStateEnum#satisfied> <https://w3id.org/lmodel/oscal_assessment_plan/ObjectiveStatusStateEnum#not-satisfied> ) ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> ;
    linkml:permissible_values <https://w3id.org/lmodel/oscal_assessment_plan/ObjectiveStatusStateEnum#not-satisfied>,
        <https://w3id.org/lmodel/oscal_assessment_plan/ObjectiveStatusStateEnum#satisfied> .

oscal_assessment_plan:PartyTypeEnum a owl:Class ;
    rdfs:label "PartyTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/oscal_assessment_plan/PartyTypeEnum#person> <https://w3id.org/lmodel/oscal_assessment_plan/PartyTypeEnum#organization> ) ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> ;
    linkml:permissible_values <https://w3id.org/lmodel/oscal_assessment_plan/PartyTypeEnum#organization>,
        <https://w3id.org/lmodel/oscal_assessment_plan/PartyTypeEnum#person> .

oscal_assessment_plan:RelatedObservation a owl:Class ;
    rdfs:label "RelatedObservation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:observation_uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:observation_uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:observation_uuid ] ;
    skos:definition "Relates the identified element to a set of referenced observations." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:RelatedTask a owl:Class ;
    rdfs:label "RelatedTask" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:task_uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:subjects ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:task_uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:AssessmentSubject ;
            owl:onProperty oscal_assessment_plan:subjects ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:task_uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:identified_subject ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:IdentifiedSubject ;
            owl:onProperty oscal_assessment_plan:identified_subject ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:identified_subject ],
        oscal_catalog:HasResponsibleParties,
        oscal_catalog:OscalCommon ;
    skos:definition "Identifies an individual task for which the containing object is a consequence of." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:SubjectReference a owl:Class ;
    rdfs:label "SubjectReference" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:subject_uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:subject_uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:SelectSubjectTypeEnum ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:subject_uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:title ],
        oscal_catalog:OscalCommon ;
    skos:definition "A human-oriented identifier reference to a resource. Use type to indicate whether the identified resource is a component, inventory item, location, user, or something else." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:SystemComponent a owl:Class ;
    rdfs:label "SystemComponent" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:purpose ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:protocols ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:purpose ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ComponentStatus ;
            owl:onProperty oscal_assessment_plan:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:purpose ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:status ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ComponentTypeEnum ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Protocol ;
            owl:onProperty oscal_assessment_plan:protocols ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        oscal_catalog:HasResponsibleRoles,
        oscal_catalog:OscalCommon ;
    skos:definition "A defined component that can be part of an implemented system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:TaskTypeEnum a owl:Class ;
    rdfs:label "TaskTypeEnum" ;
    owl:unionOf ( <https://w3id.org/lmodel/oscal_assessment_plan/TaskTypeEnum#milestone> <https://w3id.org/lmodel/oscal_assessment_plan/TaskTypeEnum#action> ) ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> ;
    linkml:permissible_values <https://w3id.org/lmodel/oscal_assessment_plan/TaskTypeEnum#action>,
        <https://w3id.org/lmodel/oscal_assessment_plan/TaskTypeEnum#milestone> .

oscal_assessment_plan:activity_uuid a owl:DatatypeProperty ;
    rdfs:label "activity-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A UUID reference to an activity." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:actor_uuid a owl:DatatypeProperty ;
    rdfs:label "actor-uuid" ;
    rdfs:range xsd:string ;
    skos:definition "A machine-oriented identifier reference to the tool or person based on the associated type." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:assessment_assets a owl:ObjectProperty ;
    rdfs:label "assessment-assets" ;
    rdfs:range oscal_assessment_plan:AssessmentAssets ;
    skos:definition "Identifies the assets used to perform this assessment." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:assessment_plan a owl:ObjectProperty ;
    rdfs:label "assessment-plan" ;
    rdfs:range oscal_assessment_plan:AssessmentPlan ;
    skos:definition "The root assessment plan object." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:at_frequency a owl:ObjectProperty ;
    rdfs:label "at-frequency" ;
    rdfs:range oscal_assessment_plan:AtFrequency ;
    skos:definition "The task is intended to occur at the specified frequency." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:collected a owl:DatatypeProperty ;
    rdfs:label "collected" ;
    rdfs:range xsd:dateTime ;
    skos:definition "Date/time stamp identifying when the finding information was collected." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:deadline a owl:DatatypeProperty ;
    rdfs:label "deadline" ;
    rdfs:range xsd:dateTime ;
    skos:definition "The date/time by which the risk must be resolved." ;
