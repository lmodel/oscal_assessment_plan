oscal_assessment_plan:Origin a owl:Class ;
    rdfs:label "Origin" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:actors ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:related_tasks ],
