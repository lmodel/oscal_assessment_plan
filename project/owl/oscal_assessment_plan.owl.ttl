    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:depends_on a owl:DatatypeProperty ;
    rdfs:label "depends-on" ;
    rdfs:range xsd:string ;
    skos:definition "(deprecated) Another parameter invoking this one. This construct has been deprecated and should not be used." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:expression a owl:DatatypeProperty ;
    rdfs:label "expression" ;
    rdfs:range xsd:string ;
