        <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPartNameEnum#objective> .

oscal_assessment_plan:AssessmentSelectControlById a owl:Class ;
    rdfs:label "AssessmentSelectControlById" ;
    rdfs:subClassOf [ a owl:Restriction ;
