    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_catalog:Action a owl:Class ;
    rdfs:label "Action" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:system ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty oscal_catalog:system ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty oscal_catalog:date ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:system ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:date ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:date ],
        oscal_catalog:HasResponsibleParties,
        oscal_catalog:OscalCommon ;
    skos:definition "An action applied by a role within a given party to the content." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:Base64Resource a owl:Class ;
    rdfs:label "Base64Resource" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:base64Binary ;
            owl:onProperty oscal_catalog:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:media_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:media_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:value ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:value ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:media_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:filename ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:filename ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:filename ] ;
    skos:definition "A resource encoded using the Base64 alphabet defined by RFC 2045." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:Catalog a owl:Class ;
    rdfs:label "Catalog" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:back_matter ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Metadata ;
            owl:onProperty oscal_catalog:metadata ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:back_matter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:controls ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:metadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Control ;
            owl:onProperty oscal_catalog:controls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:metadata ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:BackMatter ;
            owl:onProperty oscal_catalog:back_matter ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:params ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Parameter ;
            owl:onProperty oscal_catalog:params ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:groups ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Group ;
            owl:onProperty oscal_catalog:groups ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ] ;
    skos:definition "A structured, organized collection of control information." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:Citation a owl:Class ;
    rdfs:label "Citation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:text ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:text ],
        oscal_catalog:HasPropsAndLinks ;
    skos:definition "An optional citation consisting of end note text using structured markup." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:ConstraintTest a owl:Class ;
    rdfs:label "ConstraintTest" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:expression ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:expression ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:expression ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ] ;
    skos:definition "A test expression which is expected to be evaluated by a tool." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:ControlMatching a owl:Class ;
    rdfs:label "ControlMatching" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:pattern ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:pattern ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:pattern ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ] ;
    skos:definition "Selecting a set of controls by matching their IDs with a wildcard pattern." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:Hash a owl:Class ;
    rdfs:label "Hash" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:value ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:value ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:algorithm ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:HashAlgorithmEnum ;
            owl:onProperty oscal_catalog:algorithm ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:algorithm ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:value ] ;
    skos:definition "A representation of a cryptographic digest generated over a resource using a specified hash algorithm." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:Link a owl:Class ;
    rdfs:label "Link" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:resource_fragment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty oscal_catalog:href ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:rel ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:text ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:media_type ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:media_type ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:media_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:href ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:href ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:rel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:resource_fragment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:resource_fragment ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:text ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:rel ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:text ] ;
    skos:definition "A reference to a local or remote resource, that has a specific relation to the containing object." ;
