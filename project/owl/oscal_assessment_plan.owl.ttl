@prefix dcterms: <http://purl.org/dc/terms/> .
@prefix linkml: <https://w3id.org/linkml/> .
@prefix oscal_assessment_plan: <https://w3id.org/lmodel/oscal_assessment_plan/> .
@prefix oscal_catalog: <https://w3id.org/lmodel/oscal_catalog/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

<https://w3id.org/lmodel/oscal_assessment_plan.owl.ttl> a owl:Ontology ;
    rdfs:label "oscal_assessment_plan" ;
    dcterms:license "Apache-2.0" ;
    dcterms:source <https://pages.nist.gov/OSCAL-Reference/release-assets/latest/oscal_assessment-plan_schema.json> ;
    dcterms:title "oscal_assessment_plan" ;
    rdfs:seeAlso <https://lmodel.github.io/oscal_assessment_plan>,
        <https://medium.com/@gregelin/an-orientation-to-oscal-in-the-devsecops-pipeline-b51e45f8503b>,
        <https://pages.nist.gov/OSCAL/learn/concepts/layer/assessment/assessment-plan/> ;
    skos:definition "OSCAL Assessment Plan Model: LinkML Schema" .

oscal_assessment_plan:AssessmentMethod a owl:Class ;
    rdfs:label "AssessmentMethod" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:AssessmentPart ;
            owl:onProperty oscal_assessment_plan:part ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:part ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:part ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        oscal_catalog:OscalCommon ;
    skos:definition "A local definition of a control objective." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:AssessmentPlanDocument a owl:Class ;
    rdfs:label "AssessmentPlanDocument" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:AssessmentPlan ;
            owl:onProperty oscal_assessment_plan:assessment_plan ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:assessment_plan ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:assessment_plan ],
        oscal_catalog:OscalDocument ;
    skos:definition "Root wrapper for an OSCAL Assessment Plan document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:AssessmentSubjectPlaceholder a owl:Class ;
    rdfs:label "AssessmentSubjectPlaceholder" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:AssessmentSubjectSource ;
            owl:onProperty oscal_assessment_plan:sources ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:sources ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        oscal_catalog:OscalCommon ;
    skos:definition "Used when the assessment subjects will be determined as part of one or more other assessment activities." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:Finding a owl:Class ;
    rdfs:label "Finding" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:implementation_statement_uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:target ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Origin ;
            owl:onProperty oscal_assessment_plan:origins ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:FindingTarget ;
            owl:onProperty oscal_assessment_plan:target ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:implementation_statement_uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:target ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:related_risks ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:related_observations ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:RelatedObservation ;
            owl:onProperty oscal_assessment_plan:related_observations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:origins ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:AssociatedRisk ;
            owl:onProperty oscal_assessment_plan:related_risks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:implementation_statement_uuid ],
        oscal_catalog:OscalCommon ;
    skos:definition "Describes an individual finding." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:Observation a owl:Class ;
    rdfs:label "Observation" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ObservationTypeEnum ;
            owl:onProperty oscal_assessment_plan:types ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:collected ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ObservationMethodEnum ;
            owl:onProperty oscal_assessment_plan:methods ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty oscal_assessment_plan:expires ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:SubjectReference ;
            owl:onProperty oscal_assessment_plan:subjects ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:relevant_evidence ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:expires ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:expires ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:collected ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Origin ;
            owl:onProperty oscal_assessment_plan:origins ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:methods ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:origins ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:types ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:RelevantEvidence ;
            owl:onProperty oscal_assessment_plan:relevant_evidence ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:subjects ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty oscal_assessment_plan:collected ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        oscal_catalog:OscalCommon ;
    skos:definition "Describes an individual observation." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:Risk a owl:Class ;
    rdfs:label "Risk" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:characterizations ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:threat_ids ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:deadline ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:RelatedObservation ;
            owl:onProperty oscal_assessment_plan:related_observations ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:related_observations ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:risk_log ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Response ;
            owl:onProperty oscal_assessment_plan:remediations ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:status ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:MitigatingFactor ;
            owl:onProperty oscal_assessment_plan:mitigating_factors ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:statement ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:origins ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:RiskStatusEnum ;
            owl:onProperty oscal_assessment_plan:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:statement ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Origin ;
            owl:onProperty oscal_assessment_plan:origins ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:remediations ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ThreatId ;
            owl:onProperty oscal_assessment_plan:threat_ids ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Characterization ;
            owl:onProperty oscal_assessment_plan:characterizations ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:status ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:dateTime ;
            owl:onProperty oscal_assessment_plan:deadline ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:statement ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:deadline ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:RiskLog ;
            owl:onProperty oscal_assessment_plan:risk_log ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:risk_log ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:mitigating_factors ],
        oscal_catalog:HasPropsAndLinks ;
    skos:definition "An identified risk." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:SetParameter a owl:Class ;
    rdfs:label "SetParameter" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:values ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_assessment_plan:param_id ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:param_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:param_id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:values ] ;
    skos:definition "Identifies the parameter that will be set by the enclosed value." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:SystemId a owl:Class ;
    rdfs:label "SystemId" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:id ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:identifier_type ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:id ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:identifier_type ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:id ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:anyURI ;
            owl:onProperty oscal_assessment_plan:identifier_type ] ;
    skos:definition "A human-oriented, globally unique identifier for a system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_catalog:CatalogDocument a owl:Class ;
    rdfs:label "CatalogDocument" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:Catalog ;
            owl:onProperty oscal_catalog:catalog ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:catalog ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:catalog ],
        oscal_catalog:OscalDocument ;
    skos:definition "Root wrapper for an OSCAL Catalog document." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

oscal_catalog:SelectControlById a owl:Class ;
    rdfs:label "SelectControlById" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:with_ids ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_catalog:ControlMatching ;
            owl:onProperty oscal_catalog:matching ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:with_child_controls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:with_child_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:WithChildControlsEnum ;
            owl:onProperty oscal_catalog:with_child_controls ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:matching ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:with_ids ] ;
    skos:definition "Select a control or controls from an imported control set." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_catalog> .

xsd:base64Binary a rdfs:Datatype .

oscal_assessment_plan:ComponentStatus a owl:Class ;
    rdfs:label "ComponentStatus" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:state ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ComponentStateEnum ;
            owl:onProperty oscal_catalog:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:state ] ;
    skos:definition "Describes the operational status of the system component." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:ObjectiveStatus a owl:Class ;
    rdfs:label "ObjectiveStatus" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:reason ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ObjectiveStatusReasonEnum ;
            owl:onProperty oscal_assessment_plan:reason ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:remarks ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ObjectiveStatusStateEnum ;
            owl:onProperty oscal_catalog:state ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:state ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:state ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:reason ] ;
    skos:definition "A determination of if the objective is satisfied or not within a given system." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

oscal_assessment_plan:Activity a owl:Class ;
    rdfs:label "Activity" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:ReviewedControls ;
            owl:onProperty oscal_assessment_plan:related_controls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_assessment_plan:related_controls ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_catalog:uuid ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:steps ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_catalog:title ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:related_controls ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:Step ;
            owl:onProperty oscal_assessment_plan:steps ],
        [ a owl:Restriction ;
            owl:maxCardinality 1 ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:description ],
        [ a owl:Restriction ;
            owl:allValuesFrom xsd:string ;
            owl:onProperty oscal_catalog:title ],
        oscal_catalog:HasResponsibleRoles,
        oscal_catalog:OscalCommon ;
    skos:definition "Identifies an assessment or related process that can be performed. In the assessment plan, this is an intended activity." ;
    skos:inScheme <https://w3id.org/lmodel/oscal_assessment_plan> .

<https://w3id.org/lmodel/oscal_assessment_plan/AddressTypeEnum#home> a owl:Class ;
    rdfs:label "home" ;
    rdfs:subClassOf oscal_assessment_plan:AddressTypeEnum .

<https://w3id.org/lmodel/oscal_assessment_plan/AddressTypeEnum#work> a owl:Class ;
    rdfs:label "work" ;
    rdfs:subClassOf oscal_assessment_plan:AddressTypeEnum .

oscal_assessment_plan:AssessmentAssets a owl:Class ;
    rdfs:label "AssessmentAssets" ;
    rdfs:subClassOf [ a owl:Restriction ;
            owl:minCardinality 1 ;
            owl:onProperty oscal_assessment_plan:assessment_platforms ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:SystemComponent ;
            owl:onProperty oscal_assessment_plan:components ],
        [ a owl:Restriction ;
            owl:minCardinality 0 ;
            owl:onProperty oscal_assessment_plan:components ],
        [ a owl:Restriction ;
            owl:allValuesFrom oscal_assessment_plan:AssessmentPlatform ;
