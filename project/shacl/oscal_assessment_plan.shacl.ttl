        [ sh:class oscal_catalog:Group ;
            sh:description "A collection of control groups." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:groups ] ;
    sh:targetClass oscal_catalog:Catalog .

oscal_catalog:Citation a sh:NodeShape ;
    rdfs:comment "An optional citation consisting of end note text using structured markup." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
