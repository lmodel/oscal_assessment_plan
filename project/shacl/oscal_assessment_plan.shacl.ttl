            sh:order 3 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:ControlPart ;
            sh:description "A collection of parts." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_catalog:parts ] ;
    sh:targetClass oscal_assessment_plan:LocalObjective .

oscal_assessment_plan:LoggedBy a sh:NodeShape ;
    rdfs:comment "Used to indicate who created a log entry in what role." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A reference to a role by its identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:role_id ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented identifier reference to the party who is making the log entry." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:party_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass oscal_assessment_plan:LoggedBy .

oscal_assessment_plan:MitigatingFactor a sh:NodeShape ;
    rdfs:comment "Describes an existing mitigating factor that may affect the overall determination of the risk." ;
