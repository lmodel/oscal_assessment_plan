        [ sh:datatype xsd:string ;
            sh:description "A reference to a control by its identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:control_id ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
