            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:media_type ] ;
    sh:targetClass oscal_catalog:Base64Resource .

oscal_catalog:Catalog a sh:NodeShape ;
    rdfs:comment "A structured, organized collection of control information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Control ;
            sh:description "A collection of controls." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:controls ],
        [ sh:class oscal_catalog:Parameter ;
            sh:description "Parameters providing a mechanism for the dynamic assignment of value(s) in a control." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:params ],
        [ sh:class oscal_catalog:Metadata ;
            sh:description "Provides information about the containing document, and defines concepts shared across the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
