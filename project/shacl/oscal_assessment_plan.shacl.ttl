@prefix oscal_assessment_plan: <https://w3id.org/lmodel/oscal_assessment_plan/> .
@prefix oscal_catalog: <https://w3id.org/lmodel/oscal_catalog/> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

oscal_assessment_plan:AssessmentMethod a sh:NodeShape ;
    rdfs:comment "A local definition of a control objective." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_assessment_plan:AssessmentPart ;
            sh:description "An assessment part." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:part ] ;
    sh:targetClass oscal_assessment_plan:AssessmentMethod .

oscal_assessment_plan:AssessmentPlanDocument a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Assessment Plan document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:AssessmentPlan ;
            sh:description "The root assessment plan object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:assessment_plan ] ;
    sh:targetClass oscal_assessment_plan:AssessmentPlanDocument .

oscal_assessment_plan:AssessmentSubjectPlaceholder a sh:NodeShape ;
    rdfs:comment "Used when the assessment subjects will be determined as part of one or more other assessment activities." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:AssessmentSubjectSource ;
            sh:description "Activities that will identify assessment subjects." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:sources ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:AssessmentSubjectPlaceholder .

oscal_assessment_plan:Finding a sh:NodeShape ;
    rdfs:comment "Describes an individual finding." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:AssociatedRisk ;
            sh:description "Relates the finding to a set of referenced risks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_assessment_plan:related_risks ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "A reference to the implementation statement in the SSP to which this finding is related." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:implementation_statement_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_assessment_plan:RelatedObservation ;
            sh:description "Relates the containing object to a set of referenced observations." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:related_observations ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:FindingTarget ;
            sh:description "Identifies the target of a finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:target ],
        [ sh:class oscal_assessment_plan:Origin ;
            sh:description "Identifies the source of observations, findings, or risks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:origins ] ;
    sh:targetClass oscal_assessment_plan:Finding .

oscal_assessment_plan:Observation a sh:NodeShape ;
    rdfs:comment "Describes an individual observation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 10 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Date/time identifying when the finding information is no longer considered valid." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path oscal_assessment_plan:expires ],
        [ sh:description "Identifies how the observation was made." ;
            sh:in ( "EXAMINE" "INTERVIEW" "TEST" "UNKNOWN" ) ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:methods ],
        [ sh:class oscal_assessment_plan:RelevantEvidence ;
            sh:description "Links the observation to relevant evidence." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_assessment_plan:relevant_evidence ],
        [ sh:class oscal_assessment_plan:Origin ;
            sh:description "Identifies the source of observations, findings, or risks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:origins ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:dateTime ;
            sh:description "Date/time stamp identifying when the finding information was collected." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path oscal_assessment_plan:collected ],
        [ sh:description "Identifies the nature of the observation." ;
            sh:in ( "ssp-statement-issue" "control-objective" "mitigation" "finding" "discovery" "historic" ) ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:types ],
        [ sh:class oscal_assessment_plan:SubjectReference ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:subjects ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:Observation .

oscal_assessment_plan:Risk a sh:NodeShape ;
    rdfs:comment "An identified risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "An assessor's summary of the risk, in narrative form." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:statement ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_assessment_plan:RelatedObservation ;
            sh:description "Relates the containing object to a set of referenced observations." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path oscal_assessment_plan:related_observations ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_assessment_plan:RiskLog ;
            sh:description "A log of all risk-related tasks taken." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path oscal_assessment_plan:risk_log ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:ThreatId ;
            sh:description "The referenced threat identifiers." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:threat_ids ],
        [ sh:description "Indicates the status of the containing object." ;
            sh:in ( "open" "investigating" "remediating" "deviation-requested" "deviation-approved" "closed" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 12 ;
            sh:path oscal_assessment_plan:status ],
        [ sh:class oscal_assessment_plan:Characterization ;
            sh:description "Supporting information about the risk and how it relates to the system." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:characterizations ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_assessment_plan:Response ;
            sh:description "Describes either recommended or actual responses to a risk." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_assessment_plan:remediations ],
        [ sh:class oscal_assessment_plan:MitigatingFactor ;
            sh:description "Describes existing mitigating factors that may affect the overall determination of the risk." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_assessment_plan:mitigating_factors ],
        [ sh:class oscal_assessment_plan:Origin ;
            sh:description "Identifies the source of observations, findings, or risks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:origins ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date/time by which the risk must be resolved." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path oscal_assessment_plan:deadline ] ;
    sh:targetClass oscal_assessment_plan:Risk .

oscal_assessment_plan:SetParameter a sh:NodeShape ;
    rdfs:comment "Identifies the parameter that will be set by the enclosed value." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A reference to a parameter by its identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:param_id ],
        [ sh:datatype xsd:string ;
            sh:description "A parameter value or set of values." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:values ] ;
    sh:targetClass oscal_assessment_plan:SetParameter .

oscal_assessment_plan:SystemId a sh:NodeShape ;
    rdfs:comment "A human-oriented, globally unique identifier for a system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A unique human-oriented identifier within a particular context." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:id ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A human-readable label for a specific identifier scheme." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:identifier_type ] ;
    sh:targetClass oscal_assessment_plan:SystemId .

oscal_catalog:CatalogDocument a sh:NodeShape ;
    rdfs:comment "Root wrapper for an OSCAL Catalog document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Catalog ;
            sh:description "Root catalog document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_catalog:catalog ] ;
    sh:targetClass oscal_catalog:CatalogDocument .

oscal_catalog:HasPropsAndLinks a sh:NodeShape ;
    rdfs:comment "Mixin providing the props and links slots that are common to many OSCAL objects." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_catalog:HasPropsAndLinks .

oscal_catalog:HasResponsibleParties a sh:NodeShape ;
    rdfs:comment "Mixin providing the responsible-parties slot for objects that carry party assignments." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:ResponsibleParty ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_catalog:responsible_parties ] ;
    sh:targetClass oscal_catalog:HasResponsibleParties .

oscal_catalog:HasResponsibleRoles a sh:NodeShape ;
    rdfs:comment "Mixin providing the responsible-roles slot for objects that carry role assignments." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:ResponsibleRole ;
            sh:description "Responsible role assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_catalog:responsible_roles ] ;
    sh:targetClass oscal_catalog:HasResponsibleRoles .

oscal_catalog:OscalCommon a sh:NodeShape ;
    rdfs:comment "Mixin providing props, links, and remarks slots common to most OSCAL objects. Extends HasPropsAndLinks." ;
    sh:closed false ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_catalog:OscalCommon .

oscal_catalog:OscalDocument a sh:NodeShape ;
    rdfs:comment "A root wrapper for an OSCAL document, which may be of any OSCAL document type (e.g. Catalog, Profile, Assessment Plan, SSP)." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type oscal_assessment_plan:assessment_plan oscal_catalog:catalog ) ;
    sh:targetClass oscal_catalog:OscalDocument .

oscal_catalog:SelectControlById a sh:NodeShape ;
    rdfs:comment "Select a control or controls from an imported control set." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "When a control is included, whether its child (dependent) controls are also included." ;
            sh:in ( "True" "False" ) ;
            sh:maxCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:with_child_controls ],
        [ sh:class oscal_catalog:ControlMatching ;
            sh:description "Selecting a set of controls by matching their IDs with a wildcard pattern." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_catalog:matching ],
        [ sh:datatype xsd:string ;
            sh:description "Selecting a control by its ID given as a literal." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:with_ids ] ;
    sh:targetClass oscal_catalog:SelectControlById .

oscal_assessment_plan:Activity a sh:NodeShape ;
    rdfs:comment "Identifies an assessment or related process that can be performed. In the assessment plan, this is an intended activity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:ResponsibleRole ;
            sh:description "Responsible role assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:responsible_roles ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:ReviewedControls ;
            sh:description "A reference to reviewed controls for this activity or step." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:related_controls ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_assessment_plan:Step ;
            sh:description "A collection of steps in an activity." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:steps ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:Activity .

oscal_assessment_plan:AssessmentAssets a sh:NodeShape ;
    rdfs:comment "Identifies the assets used to perform this assessment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:AssessmentPlatform ;
            sh:description "A collection of assessment platforms." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:assessment_platforms ],
        [ sh:class oscal_assessment_plan:SystemComponent ;
            sh:description "A collection of system components." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:components ] ;
    sh:targetClass oscal_assessment_plan:AssessmentAssets .

oscal_assessment_plan:AssessmentPlan a sh:NodeShape ;
    rdfs:comment "An assessment plan, such as those provided by a FedRAMP assessor." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Metadata ;
            sh:description "Provides information about the containing document, and defines concepts shared across the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_catalog:metadata ],
        [ sh:datatype xsd:string ;
            sh:description "Assessment Plan Universally Unique Identifier." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_assessment_plan:TermsAndConditions ;
            sh:description "Terms and conditions under which an assessment can be performed." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:terms_and_conditions ],
        [ sh:class oscal_assessment_plan:Task ;
            sh:description "A collection of tasks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_assessment_plan:tasks ],
        [ sh:class oscal_assessment_plan:LocalDefinitions ;
            sh:description "Used to define data objects that do not appear in the referenced SSP." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:local_definitions ],
        [ sh:class oscal_assessment_plan:ReviewedControls ;
            sh:description "Identifies the controls being assessed and their control objectives." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_assessment_plan:reviewed_controls ],
        [ sh:class oscal_catalog:BackMatter ;
            sh:description "A collection of resources that may be referenced from within the OSCAL document instance." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_catalog:back_matter ],
        [ sh:class oscal_assessment_plan:AssessmentAssets ;
            sh:description "Identifies the assets used to perform this assessment." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:assessment_assets ],
        [ sh:class oscal_assessment_plan:ImportSSP ;
            sh:description "Used to import information about the system from an SSP." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:import_ssp ],
        [ sh:class oscal_assessment_plan:AssessmentSubject ;
            sh:description "Identifies system elements being assessed." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:assessment_subjects ] ;
    sh:targetClass oscal_assessment_plan:AssessmentPlan .

oscal_assessment_plan:AssessmentPlatform a sh:NodeShape ;
    rdfs:comment "Used to represent the toolset used to perform aspects of the assessment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:UsesComponent ;
            sh:description "The set of components used by the assessment platform." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:uses_components ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:AssessmentPlatform .

oscal_assessment_plan:AssessmentSubjectSource a sh:NodeShape ;
    rdfs:comment "Assessment subjects will be identified while conducting the referenced activity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A UUID reference to a task." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:task_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass oscal_assessment_plan:AssessmentSubjectSource .

oscal_assessment_plan:AssociatedActivity a sh:NodeShape ;
    rdfs:comment "Identifies an individual activity to be performed as part of a task." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A UUID reference to an activity." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:activity_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_catalog:ResponsibleRole ;
            sh:description "Responsible role assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:responsible_roles ],
        [ sh:class oscal_assessment_plan:AssessmentSubject ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:subjects ] ;
    sh:targetClass oscal_assessment_plan:AssociatedActivity .

oscal_assessment_plan:AssociatedRisk a sh:NodeShape ;
    rdfs:comment "Relates the finding to a set of referenced risks." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented identifier reference to a risk defined in the list of risks." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:risk_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass oscal_assessment_plan:AssociatedRisk .

oscal_assessment_plan:AtFrequency a sh:NodeShape ;
    rdfs:comment "The task is intended to occur at the specified frequency." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:positiveInteger ;
            sh:description "The task must occur every period (in the given units)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:period ],
        [ sh:description "The unit of time for the period." ;
            sh:in ( "seconds" "minutes" "hours" "days" "months" "years" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:unit ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:AtFrequency .

oscal_assessment_plan:AuthorizedPrivilege a sh:NodeShape ;
    rdfs:comment "Identifies a specific system privilege held by the user, along with an associated description and/or rationale for the privilege." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "Describes a function performed for a given authorized privilege." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:functions_performed ] ;
    sh:targetClass oscal_assessment_plan:AuthorizedPrivilege .

oscal_assessment_plan:Characterization a sh:NodeShape ;
    rdfs:comment "A collection of descriptive data about the containing object from a specific origin." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_assessment_plan:Origin ;
            sh:description "The source of the finding." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:origin ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:Facet ;
            sh:description "An individual characteristic that is part of a larger set produced by the same actor." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:facets ] ;
    sh:targetClass oscal_assessment_plan:Characterization .

oscal_assessment_plan:ComponentStatus a sh:NodeShape ;
    rdfs:comment "Describes the operational status of the system component." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "The operational status." ;
            sh:in ( "under-development" "operational" "disposition" "other" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:state ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:ComponentStatus .

oscal_assessment_plan:ControlObjectiveSelection a sh:NodeShape ;
    rdfs:comment "Identifies the control objectives of the assessment." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_assessment_plan:SelectObjectiveById ;
            sh:description "Objectives to exclude from the assessment." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:exclude_objectives ],
        [ sh:class oscal_assessment_plan:SelectObjectiveById ;
            sh:description "Objectives to include in the assessment." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:include_objectives ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:IncludeAll ;
            sh:description "Include all controls from the imported catalog or profile resources." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:include_all ] ;
    sh:targetClass oscal_assessment_plan:ControlObjectiveSelection .

oscal_assessment_plan:ControlSelection a sh:NodeShape ;
    rdfs:comment "Identifies the controls being assessed." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:IncludeAll ;
            sh:description "Include all controls from the imported catalog or profile resources." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:include_all ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_assessment_plan:AssessmentSelectControlById ;
            sh:description "Controls to include in the assessment." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:include_controls ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:AssessmentSelectControlById ;
            sh:description "Controls to exclude from the assessment." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:exclude_controls ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:ControlSelection .

oscal_assessment_plan:EventTiming a sh:NodeShape ;
    rdfs:comment "The timing under which the task is intended to occur." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:AtFrequency ;
            sh:description "The task is intended to occur at the specified frequency." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:at_frequency ],
        [ sh:class oscal_assessment_plan:OnDateCondition ;
            sh:description "The task is intended to occur on the specified date." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:on_date ],
        [ sh:class oscal_assessment_plan:WithinDateRange ;
            sh:description "The task is intended to occur within the specified date range." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:within_date_range ] ;
    sh:targetClass oscal_assessment_plan:EventTiming .

oscal_assessment_plan:Facet a sh:NodeShape ;
    rdfs:comment "An individual characteristic that is part of a larger set produced by the same actor." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:anyURI ;
            sh:description "Specifies the system or scheme from which the identifier originates." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:system ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that uniquely identifies an attribute or semantic type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:name ],
        [ sh:datatype xsd:string ;
            sh:description "The value associated with the containing object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:value ] ;
    sh:targetClass oscal_assessment_plan:Facet .

oscal_assessment_plan:FindingTarget a sh:NodeShape ;
    rdfs:comment "Captures an assessor's conclusions regarding the degree to which an objective is satisfied." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:ObjectiveStatus ;
            sh:description "Indicates the status of the containing object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:status ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:links ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:in ( "statement-id" "objective-id" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:type ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies the specific target qualified by the type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:target_id ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:title ],
        [ sh:class oscal_assessment_plan:ImplementationStatus ;
            sh:description "Identifies the implementation status of the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:implementation_status ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:FindingTarget .

oscal_assessment_plan:IdentifiedSubject a sh:NodeShape ;
    rdfs:comment "Used to detail assessment subjects that were identified by this task." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:AssessmentSubject ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:subjects ],
        [ sh:datatype xsd:string ;
            sh:description "A reference to an assessment subject placeholder defined in the assessment plan." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:subject_placeholder_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass oscal_assessment_plan:IdentifiedSubject .

oscal_assessment_plan:ImplementationStatus a sh:NodeShape ;
    rdfs:comment "Indicates the degree to which a given control is implemented." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "Identifies the implementation status of the control or control objective." ;
            sh:in ( "implemented" "partial" "planned" "alternative" "not-applicable" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:state ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:ImplementationStatus .

oscal_assessment_plan:ImplementedComponent a sh:NodeShape ;
    rdfs:comment "The set of components that are implemented in a given system inventory item." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A UUID reference to a component." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:component_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:ResponsibleParty ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_catalog:responsible_parties ] ;
    sh:targetClass oscal_assessment_plan:ImplementedComponent .

oscal_assessment_plan:ImportSSP a sh:NodeShape ;
    rdfs:comment "Used by the assessment plan and POA&M to import information about the system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A resolvable URL reference to a resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:href ] ;
    sh:targetClass oscal_assessment_plan:ImportSSP .

oscal_assessment_plan:InventoryItem a sh:NodeShape ;
    rdfs:comment "A single managed inventory item within the system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:ImplementedComponent ;
            sh:description "A collection of implemented components." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:implemented_components ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_catalog:ResponsibleParty ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:responsible_parties ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:InventoryItem .

oscal_assessment_plan:LocalDefinitions a sh:NodeShape ;
    rdfs:comment "Used to define data objects that are used in the assessment plan, that do not appear in the referenced SSP." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:Activity ;
            sh:description "A collection of activities." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:activities ],
        [ sh:class oscal_assessment_plan:SystemUser ;
            sh:description "A collection of system users." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:users ],
        [ sh:class oscal_assessment_plan:InventoryItem ;
            sh:description "A collection of inventory items." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:inventory_items ],
        [ sh:class oscal_assessment_plan:SystemComponent ;
            sh:description "A collection of system components." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:components ],
        [ sh:class oscal_assessment_plan:LocalObjective ;
