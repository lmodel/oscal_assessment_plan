        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:RelevantEvidence .

oscal_assessment_plan:RequiredAsset a sh:NodeShape ;
    rdfs:comment "Identifies an asset required to achieve remediation." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_assessment_plan:SubjectReference ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:subjects ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ] ;
    sh:targetClass oscal_assessment_plan:RequiredAsset .

oscal_assessment_plan:Response a sh:NodeShape ;
    rdfs:comment "Describes either recommended or an actual plan for addressing the risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:class oscal_assessment_plan:RequiredAsset ;
            sh:description "Identifies an asset required to achieve remediation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:required_assets ],
        [ sh:class oscal_assessment_plan:Task ;
            sh:description "A collection of tasks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:tasks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:Origin ;
            sh:description "Identifies the source of observations, findings, or risks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:origins ],
        [ sh:description "Identifies whether this is a recommendation or an actual plan." ;
            sh:in ( "recommendation" "planned" "completed" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:lifecycle ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ] ;
    sh:targetClass oscal_assessment_plan:Response .

oscal_assessment_plan:RiskLog a sh:NodeShape ;
    rdfs:comment "A log of all risk-related tasks taken." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:RiskLogEntry ;
            sh:description "Identifies an individual risk response that occurred as part of managing an identified risk." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:entries ] ;
    sh:targetClass oscal_assessment_plan:RiskLog .

oscal_assessment_plan:RiskLogEntry a sh:NodeShape ;
    rdfs:comment "Identifies an individual risk response that occurred as part of managing an identified risk." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The start date/time." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:start ],
        [ sh:class oscal_assessment_plan:LoggedBy ;
            sh:description "Used to indicate who created a log entry in what role." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:logged_by ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:RiskResponseReference ;
            sh:description "Identifies an individual risk response that this log entry is for." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_assessment_plan:related_responses ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The end date/time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:end ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:description "Identifies the risk change that prompted the log entry." ;
            sh:in ( "open" "investigating" "remediating" "deviation-requested" "deviation-approved" "closed" ) ;
            sh:maxCount 1 ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:status_change ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 8 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:RiskLogEntry .

oscal_assessment_plan:RiskResponseReference a sh:NodeShape ;
    rdfs:comment "Identifies an individual risk response that this log entry is for." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
