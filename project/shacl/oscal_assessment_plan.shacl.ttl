            sh:order 8 ;
            sh:path oscal_catalog:location_uuids ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
    sh:targetClass oscal_catalog:Party .

oscal_catalog:PartyExternalId a sh:NodeShape ;
