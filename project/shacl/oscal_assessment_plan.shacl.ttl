            sh:path oscal_catalog:scheme ],
        [ sh:datatype xsd:string ;
            sh:description "A document identifier value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:identifier ] ;
    sh:targetClass oscal_catalog:DocumentId .

oscal_catalog:Group a sh:NodeShape ;
    rdfs:comment "A group of controls, or of groups of controls." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Group ;
            sh:description "A collection of control groups." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:groups ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Control ;
            sh:description "A collection of controls." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:controls ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Part ;
            sh:description "A collection of parts." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:parts ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies the group for the purpose of cross-linking within the defining instance or from other instances that reference the catalog." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:id ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_catalog:Parameter ;
            sh:description "Parameters providing a mechanism for the dynamic assignment of value(s) in a control." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:params ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the group." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:_class ],
        [ sh:datatype xsd:string ;
            sh:description "A name given to the group, which may be used by a tool for display and navigation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:title ] ;
    sh:targetClass oscal_catalog:Group .

oscal_catalog:Metadata a sh:NodeShape ;
    rdfs:comment "Provides information about the containing document, and defines concepts shared across the document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Action ;
            sh:description "An action applied by a role within a given party to the content." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path oscal_catalog:actions ],
        [ sh:class oscal_catalog:Revision ;
            sh:description "An entry in a sequential list of revisions to the containing document, expected to be in reverse chronological order (i.e. latest first)." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:revisions ],
        [ sh:datatype xsd:string ;
            sh:description "A name given to the document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:title ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 14 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Location ;
            sh:description "A physical point of presence, which may be associated with people, organizations, or other concepts within the current or linked OSCAL document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:locations ],
        [ sh:class oscal_catalog:Role ;
            sh:description "Defines a function, which might be assigned to a party in a specific situation." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:roles ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 11 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:DocumentId ;
            sh:description "Document identifiers qualified by an identifier scheme." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:document_ids ],
        [ sh:class oscal_catalog:ResponsibleParty ;
            sh:description "Responsible party assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path oscal_catalog:responsible_parties ],
        [ sh:datatype xsd:string ;
            sh:description "Used to distinguish a specific revision of an OSCAL document." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:version ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date and time the document was last stored for later retrieval." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:last_modified ],
        [ sh:datatype xsd:dateTime ;
            sh:description "The date and time the document was last made available." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:published ],
        [ sh:class oscal_catalog:Party ;
            sh:description "An organization or person, which may be associated with roles or other concepts within the current or linked OSCAL document." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 9 ;
            sh:path oscal_catalog:parties ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 13 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "The OSCAL model version the document was authored against." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:oscal_version ] ;
    sh:targetClass oscal_catalog:Metadata .

oscal_catalog:TelephoneNumber a sh:NodeShape ;
    rdfs:comment "A telephone service number as defined by ITU-T E.164." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Indicates the type of phone number. Typical values: home, office, mobile. Other values are permitted." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:type ],
        [ sh:datatype xsd:string ;
            sh:description "A telephone number value." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:number ] ;
    sh:targetClass oscal_catalog:TelephoneNumber .

oscal_assessment_plan:AssessmentPart a sh:NodeShape ;
    rdfs:comment "A partition of an assessment plan or results or a child of another part." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:description "A textual label that uniquely identifies an attribute or semantic type." ;
            sh:in ( "asset" "method" "objective" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path oscal_catalog:name ],
        [ sh:datatype xsd:anyURI ;
            sh:description "An optional namespace qualifying a name. Allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:ns ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_assessment_plan:AssessmentPart ;
            sh:description "A collection of parts." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:parts ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Permits multiple paragraphs, lists, tables etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:prose ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:_class ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:title ] ;
    sh:targetClass oscal_assessment_plan:AssessmentPart .

oscal_assessment_plan:ReviewedControls a sh:NodeShape ;
    rdfs:comment "Identifies the controls being assessed and their control objectives." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_assessment_plan:ControlSelection ;
            sh:description "Identifies the controls being assessed." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:control_selections ],
        [ sh:class oscal_assessment_plan:ControlObjectiveSelection ;
            sh:description "Identifies the control objectives of the assessment." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:control_objective_selections ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:ReviewedControls .

oscal_assessment_plan:SubjectReference a sh:NodeShape ;
    rdfs:comment "A human-oriented identifier reference to a resource. Use type to indicate whether the identified resource is a component, inventory item, location, user, or something else." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A UUID reference to the identified subject." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:subject_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:in ( "component" "inventory-item" "location" "party" "user" "resource" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path oscal_catalog:type ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:SubjectReference .

oscal_assessment_plan:Task a sh:NodeShape ;
    rdfs:comment "Represents a scheduled event or milestone, which may be associated with a series of assessment actions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:title ],
        [ sh:class oscal_assessment_plan:Task ;
            sh:description "A collection of tasks." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_assessment_plan:tasks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 12 ;
            sh:path oscal_catalog:links ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:in ( "milestone" "action" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 1 ;
            sh:path oscal_catalog:type ],
        [ sh:class oscal_assessment_plan:AssessmentSubject ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_assessment_plan:subjects ],
        [ sh:class oscal_assessment_plan:EventTiming ;
            sh:description "The timing under which a task is intended to occur." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:timing ],
        [ sh:class oscal_catalog:ResponsibleRole ;
            sh:description "Responsible role assignments." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path oscal_catalog:responsible_roles ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_assessment_plan:AssociatedActivity ;
            sh:description "Activities associated with this task." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_assessment_plan:associated_activities ],
        [ sh:class oscal_assessment_plan:TaskDependency ;
            sh:description "Tasks that this task depends on." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_assessment_plan:dependencies ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:description ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:Task .

oscal_catalog:Control a sh:NodeShape ;
    rdfs:comment "A structured object representing a requirement or guideline, which when implemented will reduce an aspect of risk related to an information system and its information." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the control." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:_class ],
        [ sh:class oscal_catalog:Parameter ;
            sh:description "Parameters providing a mechanism for the dynamic assignment of value(s) in a control." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:params ],
        [ sh:datatype xsd:string ;
            sh:description "Identifies a control such that it can be referenced in the defining catalog and other OSCAL instances (e.g., profiles)." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:id ],
        [ sh:class oscal_catalog:Part ;
            sh:description "A collection of parts." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:parts ],
        [ sh:datatype xsd:string ;
            sh:description "A name given to the control, which may be used by a tool for display and navigation." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:props ],
        [ sh:class oscal_catalog:Control ;
            sh:description "A collection of controls." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:controls ] ;
    sh:targetClass oscal_catalog:Control .

oscal_catalog:IncludeAll a sh:NodeShape ;
    rdfs:comment "Include all controls from the imported catalog or profile resources." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:targetClass oscal_catalog:IncludeAll .

oscal_catalog:Parameter a sh:NodeShape ;
    rdfs:comment "Parameters provide a mechanism for the dynamic assignment of value(s) in a control." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A parameter value or set of values." ;
            sh:nodeKind sh:Literal ;
            sh:order 7 ;
            sh:path oscal_catalog:values ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 10 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the purpose and use of a parameter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:usage ],
        [ sh:datatype xsd:string ;
            sh:description "(deprecated) Another parameter invoking this one. This construct has been deprecated and should not be used." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:depends_on ],
        [ sh:class oscal_catalog:ParameterSelection ;
            sh:description "Presenting a choice among alternatives." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:select ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a characterization of the type, purpose, use or scope of the parameter." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:_class ],
        [ sh:class oscal_catalog:ParameterGuideline ;
            sh:description "A prose statement that provides a recommendation for the use of a parameter." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:guidelines ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 11 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 9 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for the parameter." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:id ],
        [ sh:datatype xsd:string ;
            sh:description "A short, placeholder name for the parameter, which can be used as a substitute for a value if no value is assigned." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:label ],
        [ sh:class oscal_catalog:ParameterConstraint ;
            sh:description "A formal or informal expression of a constraint or test." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:constraints ] ;
    sh:targetClass oscal_catalog:Parameter .

oscal_catalog:Part a sh:NodeShape ;
    rdfs:comment "An annotated, markup-based textual element of a control's or catalog group's definition, or a child of another part." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "An optional textual providing a sub-type or characterization of the part's name, or a category to which the part belongs." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:_class ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for the part." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:id ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "An optional name given to the part, which may be used by a tool for display and navigation." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:title ],
        [ sh:datatype xsd:string ;
            sh:description "Permits multiple paragraphs, lists, tables etc." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:prose ],
        [ sh:datatype xsd:anyURI ;
            sh:description "An optional namespace qualifying the part's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:ns ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label that uniquely identifies the part's semantic type, which exists in a value space qualified by the ns." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:name ],
        [ sh:class oscal_catalog:Part ;
            sh:description "A collection of parts." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:parts ] ;
    sh:targetClass oscal_catalog:Part .

oscal_assessment_plan:AssessmentSubject a sh:NodeShape ;
    rdfs:comment "Identifies system elements being assessed, such as components, inventory items, and locations." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:IncludeAll ;
            sh:description "Include all controls from the imported catalog or profile resources." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_assessment_plan:include_all ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:in ( "component" "inventory-item" "location" "party" "user" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:type ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_assessment_plan:SelectSubjectById ;
            sh:description "Assessment subjects to exclude." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_assessment_plan:exclude_subjects ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ],
        [ sh:class oscal_assessment_plan:SelectSubjectById ;
            sh:description "Assessment subjects to include." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:include_subjects ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 6 ;
            sh:path oscal_catalog:props ] ;
    sh:targetClass oscal_assessment_plan:AssessmentSubject .

oscal_assessment_plan:Origin a sh:NodeShape ;
    rdfs:comment "Identifies the source of the finding, such as a tool, interviewed person, or activity." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_assessment_plan:RelatedTask ;
            sh:description "Identifies tasks for which the containing object is a consequence." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:related_tasks ],
        [ sh:class oscal_assessment_plan:OriginActor ;
            sh:description "The actor that produces an observation, a finding, or a risk." ;
            sh:minCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:actors ] ;
    sh:targetClass oscal_assessment_plan:Origin .

oscal_catalog:ResponsibleRole a sh:NodeShape ;
    rdfs:comment "A reference to a role with responsibility for performing a function relative to the containing object, optionally associated with a set of persons and/or organizations that perform that role." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:string ;
            sh:description "References to party UUIDs." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:party_uuids ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "A human-oriented identifier reference to a role performed." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:role_id ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:links ] ;
    sh:targetClass oscal_catalog:ResponsibleRole .

oscal_catalog:ResponsibleParty a sh:NodeShape ;
    rdfs:comment "A reference to a set of persons and/or organizations that have responsibility for performing the referenced role in the context of the containing object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "References to party UUIDs." ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:party_uuids ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "A reference to a role performed by a party." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:role_id ] ;
    sh:targetClass oscal_catalog:ResponsibleParty .

oscal_catalog:Link a sh:NodeShape ;
    rdfs:comment "A reference to a local or remote resource, that has a specific relation to the containing object." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A label that indicates the nature of a resource, as a data serialization or format." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:media_type ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label to associate with the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:text ],
        [ sh:datatype xsd:string ;
            sh:description "In case where the href points to a back-matter/resource, this value will indicate the URI fragment to append to any rlink associated with the resource. This value MUST be URI encoded." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:resource_fragment ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A resolvable URL reference to a resource." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:href ],
        [ sh:datatype xsd:string ;
            sh:description "Describes the type of relationship provided by the link's hypertext reference. This can be an indicator of the link's purpose." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:rel ] ;
    sh:targetClass oscal_catalog:Link .

oscal_catalog:Property a sh:NodeShape ;
    rdfs:comment "An attribute, characteristic, or quality of the containing object expressed as a namespace qualified name/value pair." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A textual label that provides a sub-type or characterization of the property's name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 4 ;
            sh:path oscal_catalog:_class ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:remarks ],
        [ sh:datatype xsd:anyURI ;
            sh:description "A namespace qualifying the property's name. This allows different organizations to associate distinct semantics with the same name." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:ns ],
        [ sh:datatype xsd:string ;
            sh:description "A unique identifier for a property." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "Indicates the value of the attribute, characteristic, or quality." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 3 ;
            sh:path oscal_catalog:value ],
        [ sh:datatype xsd:string ;
            sh:description "A textual label, within a namespace, that identifies a specific attribute, characteristic, or quality of the property's containing object." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:name ],
        [ sh:datatype xsd:string ;
            sh:description "An identifier for relating distinct sets of properties." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path oscal_catalog:group ] ;
    sh:targetClass oscal_catalog:Property .

