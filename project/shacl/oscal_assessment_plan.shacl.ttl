    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:links ],
        [ sh:datatype xsd:string ;
            sh:description "A reference to a role by its identifier." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:role_id ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented identifier reference to the tool or person based on the associated type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:actor_uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:description "Indicates the nature or kind of the containing object." ;
            sh:in ( "tool" "assessment-platform" "party" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:type ] ;
    sh:targetClass oscal_assessment_plan:OriginActor .

oscal_assessment_plan:PortRange a sh:NodeShape ;
    rdfs:comment "Where applicable, the transport layer protocol port range." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:nonNegativeInteger ;
            sh:description "The start date/time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_assessment_plan:start ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
