            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:LocalDefinitions .

oscal_assessment_plan:LocalObjective a sh:NodeShape ;
    rdfs:comment "A local definition of a control objective for this assessment. Uses catalog syntax for control objective and assessment actions." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:class oscal_catalog:Property ;
