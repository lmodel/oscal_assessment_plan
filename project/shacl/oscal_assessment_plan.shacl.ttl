        [ sh:datatype xsd:nonNegativeInteger ;
            sh:description "The end date/time." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:end ] ;
    sh:targetClass oscal_assessment_plan:PortRange .

oscal_assessment_plan:Protocol a sh:NodeShape ;
    rdfs:comment "Information about the protocol used to provide a service." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A textual label that uniquely identifies an attribute or semantic type." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:name ],
