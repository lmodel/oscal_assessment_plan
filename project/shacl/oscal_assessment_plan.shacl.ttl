            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 2 ;
            sh:path oscal_catalog:back_matter ],
        [ sh:datatype xsd:string ;
            sh:description "Provides a globally unique means to identify a given catalog instance." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
