        [ sh:class oscal_assessment_plan:SubjectReference ;
            sh:description "Assessment subjects or subject references for this object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_assessment_plan:subjects ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 5 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable description." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:description ] ;
    sh:targetClass oscal_assessment_plan:MitigatingFactor .

oscal_assessment_plan:ObjectiveStatus a sh:NodeShape ;
    rdfs:comment "A determination of if the objective is satisfied or not within a given system." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:remarks ],
        [ sh:description "The reason the objective was given its status." ;
            sh:in ( "pass" "fail" "other" ) ;
            sh:maxCount 1 ;
            sh:order 1 ;
            sh:path oscal_assessment_plan:reason ],
        [ sh:description "An indication as to whether the objective is satisfied or not." ;
            sh:in ( "satisfied" "not-satisfied" ) ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:order 0 ;
            sh:path oscal_catalog:state ] ;
    sh:targetClass oscal_assessment_plan:ObjectiveStatus .

oscal_assessment_plan:OnDateCondition a sh:NodeShape ;
    rdfs:comment "The task is intended to occur on the specified date." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:dateTime ;
            sh:description "The date and time when the action occurred." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:date ],
        [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:remarks ] ;
    sh:targetClass oscal_assessment_plan:OnDateCondition .

oscal_assessment_plan:OriginActor a sh:NodeShape ;
