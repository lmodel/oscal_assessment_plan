oscal_catalog:ParameterSelection a sh:NodeShape ;
    rdfs:comment "Presenting a choice among alternatives." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "A value selection among several such options." ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:choice ],
        [ sh:description "Describes the number of selections that must occur. Without this setting, only one value should be assumed to be permitted." ;
