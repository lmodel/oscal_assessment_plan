            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:value ] ;
    sh:targetClass oscal_catalog:Hash .

oscal_catalog:Location a sh:NodeShape ;
    rdfs:comment "A physical point of presence, which may be associated with people, organizations, or other concepts within the current or linked OSCAL document." ;
    sh:closed true ;
    sh:ignoredProperties ( rdf:type ) ;
    sh:property [ sh:datatype xsd:string ;
            sh:description "Additional commentary about the containing object." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 6 ;
            sh:path oscal_catalog:remarks ],
        [ sh:class oscal_catalog:Address ;
            sh:description "A postal address for the location." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 4 ;
            sh:path oscal_catalog:address ],
        [ sh:datatype xsd:string ;
            sh:description "Email addresses associated with the containing object." ;
            sh:nodeKind sh:Literal ;
            sh:order 2 ;
            sh:path oscal_catalog:email_addresses ;
            sh:pattern "^.+@.+$" ],
        [ sh:datatype xsd:anyURI ;
            sh:description "The uniform resource locator (URL) for a web site or other resource associated with the location." ;
            sh:nodeKind sh:Literal ;
            sh:order 5 ;
            sh:path oscal_catalog:urls ],
        [ sh:class oscal_catalog:Link ;
            sh:description "A list of links." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 8 ;
            sh:path oscal_catalog:links ],
        [ sh:class oscal_catalog:TelephoneNumber ;
            sh:description "Telephone numbers associated with the containing object." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 3 ;
            sh:path oscal_catalog:telephone_numbers ],
        [ sh:datatype xsd:string ;
            sh:description "A human-readable name or title." ;
            sh:maxCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 1 ;
            sh:path oscal_catalog:title ],
        [ sh:class oscal_catalog:Property ;
            sh:description "A list of properties." ;
            sh:nodeKind sh:BlankNodeOrIRI ;
            sh:order 7 ;
            sh:path oscal_catalog:props ],
        [ sh:datatype xsd:string ;
            sh:description "A machine-oriented, globally unique identifier with a cross-instance scope." ;
            sh:maxCount 1 ;
            sh:minCount 1 ;
            sh:nodeKind sh:Literal ;
            sh:order 0 ;
            sh:path oscal_catalog:uuid ;
            sh:pattern "^[0-9A-Fa-f]{8}-[0-9A-Fa-f]{4}-[45][0-9A-Fa-f]{3}-[89ABab][0-9A-Fa-f]{3}-[0-9A-Fa-f]{12}$" ] ;
