# metamodel_version: 1.7.0
BASE <https://w3id.org/lmodel/oscal_assessment_plan/>
PREFIX rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>
PREFIX oscal_catalog: <https://w3id.org/lmodel/oscal_catalog/>
PREFIX linkml: <https://w3id.org/linkml/>


linkml:String xsd:string

linkml:Integer xsd:integer

linkml:Boolean xsd:boolean

linkml:Float xsd:float

linkml:Double xsd:double

linkml:Decimal xsd:decimal

linkml:Time xsd:time

linkml:Date xsd:date

linkml:Datetime xsd:dateTime

linkml:DateOrDatetime linkml:DateOrDatetime

linkml:Uriorcurie IRI

linkml:Curie xsd:string

linkml:Uri IRI

linkml:Ncname xsd:string

linkml:Objectidentifier IRI

linkml:Nodeidentifier NONLITERAL

linkml:Jsonpointer xsd:string

linkml:Jsonpath xsd:string

linkml:Sparqlpath xsd:string

oscal_catalog:UUIDType xsd:string

oscal_catalog:URIType IRI

oscal_catalog:URIReferenceType IRI

oscal_catalog:DateTimeWithTimezoneType xsd:dateTime

oscal_catalog:MarkupLineType xsd:string

oscal_catalog:MarkupMultilineType xsd:string

oscal_catalog:TokenType xsd:string

oscal_catalog:Base64Type xsd:base64Binary

oscal_catalog:EmailAddressType xsd:string

oscal_catalog:Action CLOSED {
    (  $oscal_catalog:Action_tes (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          &oscal_catalog:HasResponsibleParties_tes ;
          rdf:type [ oscal_catalog:HasResponsibleParties ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:type @oscal_catalog:TokenType ;
          oscal_catalog:date @oscal_catalog:DateTimeWithTimezoneType ? ;
          oscal_catalog:system @oscal_catalog:URIType ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_catalog:responsible_parties @oscal_catalog:ResponsibleParty *
       ) ;
       rdf:type [ oscal_catalog:Action ] ?
    )
}

<Activity> CLOSED {
    (  $<Activity_tes> (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          &oscal_catalog:HasResponsibleRoles_tes ;
          rdf:type [ oscal_catalog:HasResponsibleRoles ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ;
          <steps> @<Step> * ;
          <related_controls> @<ReviewedControls> ? ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_catalog:responsible_roles @oscal_catalog:ResponsibleRole *
       ) ;
       rdf:type [ <Activity> ] ?
    )
}

oscal_catalog:Address CLOSED {
    (  $oscal_catalog:Address_tes (  oscal_catalog:type [ <https://w3id.org/lmodel/oscal_catalog/AddressTypeEnum#home>
             <https://w3id.org/lmodel/oscal_catalog/AddressTypeEnum#work> ] ? ;
          oscal_catalog:addr_lines @linkml:String * ;
          oscal_catalog:city @linkml:String ? ;
          oscal_catalog:state @linkml:String ? ;
          oscal_catalog:postal_code @linkml:String ? ;
          oscal_catalog:country @linkml:String ?
       ) ;
       rdf:type [ oscal_catalog:Address ] ?
    )
}

<AssessmentAssets> CLOSED {
    (  $<AssessmentAssets_tes> (  <components> @<SystemComponent> * ;
          <assessment_platforms> @<AssessmentPlatform> +
       ) ;
       rdf:type [ <AssessmentAssets> ] ?
    )
}

<AssessmentMethod> CLOSED {
    (  $<AssessmentMethod_tes> (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ? ;
          <part> @<AssessmentPart> ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ <AssessmentMethod> ] ?
    )
}

<AssessmentPart> CLOSED {
    (  $<AssessmentPart_tes> (  &oscal_catalog:HasPropsAndLinks_tes ;
          rdf:type [ oscal_catalog:HasPropsAndLinks ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ? ;
          oscal_catalog:name [ <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPartNameEnum#asset>
             <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPartNameEnum#method>
             <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentPartNameEnum#objective> ] ;
          oscal_catalog:ns @oscal_catalog:URIType ? ;
          oscal_catalog:_class @oscal_catalog:TokenType ? ;
          oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
          oscal_catalog:prose @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:parts @<AssessmentPart> * ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ <AssessmentPart> ] ?
    )
}

<AssessmentPlan> CLOSED {
    (  $<AssessmentPlan_tes> (  oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:metadata @oscal_catalog:Metadata ;
          <import_ssp> @<ImportSSP> ;
          <local_definitions> @<LocalDefinitions> ? ;
          <terms_and_conditions> @<TermsAndConditions> ? ;
          <assessment_subjects> @<AssessmentSubject> * ;
          <assessment_assets> @<AssessmentAssets> ? ;
          <reviewed_controls> @<ReviewedControls> ;
          <tasks> @<Task> * ;
          oscal_catalog:back_matter @oscal_catalog:BackMatter ?
       ) ;
       rdf:type [ <AssessmentPlan> ] ?
    )
}

<AssessmentPlanDocument> CLOSED {
    (  $<AssessmentPlanDocument_tes> (  &oscal_catalog:OscalDocument_tes ;
          rdf:type [ oscal_catalog:OscalDocument ] ? ;
          <assessment_plan> @<AssessmentPlan>
       ) ;
       rdf:type [ <AssessmentPlanDocument> ] ?
    )
}

<AssessmentPlatform> CLOSED {
    (  $<AssessmentPlatform_tes> (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:title @oscal_catalog:MarkupLineType ? ;
          <uses_components> @<UsesComponent> * ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ <AssessmentPlatform> ] ?
    )
}

<AssessmentSelectControlById> CLOSED {
    (  $<AssessmentSelectControlById_tes> (  <control_id> @oscal_catalog:TokenType ;
          <statement_ids> @oscal_catalog:TokenType *
       ) ;
       rdf:type [ <AssessmentSelectControlById> ] ?
    )
}

<AssessmentSubject> CLOSED {
    (  $<AssessmentSubject_tes> (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          oscal_catalog:type [ <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectTypeEnum#component>
             <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectTypeEnum#inventory-item>
             <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectTypeEnum#location>
             <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectTypeEnum#party>
             <https://w3id.org/lmodel/oscal_assessment_plan/AssessmentSubjectTypeEnum#user> ] ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ? ;
          <include_all> @oscal_catalog:IncludeAll ? ;
          <include_subjects> @<SelectSubjectById> * ;
          <exclude_subjects> @<SelectSubjectById> * ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ <AssessmentSubject> ] ?
    )
}

<AssessmentSubjectPlaceholder> CLOSED {
    (  $<AssessmentSubjectPlaceholder_tes> (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ? ;
          <sources> @<AssessmentSubjectSource> + ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ <AssessmentSubjectPlaceholder> ] ?
    )
}

<AssessmentSubjectSource> CLOSED {
    (  $<AssessmentSubjectSource_tes> (  <task_uuid> @oscal_catalog:UUIDType ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ?
       ) ;
       rdf:type [ <AssessmentSubjectSource> ] ?
    )
}

<AssociatedActivity> CLOSED {
    (  $<AssociatedActivity_tes> (  &oscal_catalog:OscalCommon_tes ;
          rdf:type [ oscal_catalog:OscalCommon ] ? ;
          &oscal_catalog:HasResponsibleRoles_tes ;
          rdf:type [ oscal_catalog:HasResponsibleRoles ] ? ;
          <activity_uuid> @oscal_catalog:UUIDType ;
          <subjects> @<AssessmentSubject> + ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ? ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link * ;
          oscal_catalog:responsible_roles @oscal_catalog:ResponsibleRole *
       ) ;
       rdf:type [ <AssociatedActivity> ] ?
    )
}

<AssociatedRisk> CLOSED {
    (  $<AssociatedRisk_tes> (  <risk_uuid> @oscal_catalog:UUIDType ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ?
       ) ;
       rdf:type [ <AssociatedRisk> ] ?
    )
}

<AtFrequency> CLOSED {
    (  $<AtFrequency_tes> (  <period> @linkml:Integer ;
          <unit> [ <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#seconds>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#minutes>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#hours>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#days>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#months>
             <https://w3id.org/lmodel/oscal_assessment_plan/TimingUnitEnum#years> ] ;
          oscal_catalog:remarks @oscal_catalog:MarkupMultilineType ?
       ) ;
       rdf:type [ <AtFrequency> ] ?
    )
}

<AuthorizedPrivilege> CLOSED {
    (  $<AuthorizedPrivilege_tes> (  oscal_catalog:title @oscal_catalog:MarkupLineType ;
          oscal_catalog:description @oscal_catalog:MarkupMultilineType ? ;
          <functions_performed> @linkml:String +
       ) ;
       rdf:type [ <AuthorizedPrivilege> ] ?
    )
}

oscal_catalog:BackMatter CLOSED {
    (  $oscal_catalog:BackMatter_tes oscal_catalog:resources @oscal_catalog:Resource * ;
       rdf:type [ oscal_catalog:BackMatter ] ?
    )
}

oscal_catalog:Base64Resource CLOSED {
    (  $oscal_catalog:Base64Resource_tes (  oscal_catalog:media_type @linkml:String ? ;
          oscal_catalog:value @oscal_catalog:Base64Type ;
          oscal_catalog:filename @oscal_catalog:TokenType ?
       ) ;
       rdf:type [ oscal_catalog:Base64Resource ] ?
    )
}

oscal_catalog:Catalog CLOSED {
    (  $oscal_catalog:Catalog_tes (  oscal_catalog:uuid @oscal_catalog:UUIDType ;
          oscal_catalog:metadata @oscal_catalog:Metadata ;
          oscal_catalog:back_matter @oscal_catalog:BackMatter ? ;
          oscal_catalog:params @oscal_catalog:Parameter * ;
          oscal_catalog:controls @oscal_catalog:Control * ;
          oscal_catalog:groups @oscal_catalog:Group *
       ) ;
       rdf:type [ oscal_catalog:Catalog ] ?
    )
}

oscal_catalog:CatalogDocument CLOSED {
    (  $oscal_catalog:CatalogDocument_tes (  &oscal_catalog:OscalDocument_tes ;
          rdf:type [ oscal_catalog:OscalDocument ] ? ;
          oscal_catalog:catalog @oscal_catalog:Catalog
       ) ;
       rdf:type [ oscal_catalog:CatalogDocument ] ?
    )
}

<Characterization> CLOSED {
    (  $<Characterization_tes> (  &oscal_catalog:HasPropsAndLinks_tes ;
          rdf:type [ oscal_catalog:HasPropsAndLinks ] ? ;
          <origin> @<Origin> ;
          <facets> @<Facet> + ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ <Characterization> ] ?
    )
}

oscal_catalog:Citation CLOSED {
    (  $oscal_catalog:Citation_tes (  &oscal_catalog:HasPropsAndLinks_tes ;
          rdf:type [ oscal_catalog:HasPropsAndLinks ] ? ;
          oscal_catalog:text @oscal_catalog:MarkupLineType ;
          oscal_catalog:props @oscal_catalog:Property * ;
          oscal_catalog:links @oscal_catalog:Link *
       ) ;
       rdf:type [ oscal_catalog:Citation ] ?
    )
}

<ComponentStatus> CLOSED {
    (  $<ComponentStatus_tes> (  oscal_catalog:state [
             <https://w3id.org/lmodel/oscal_assessment_plan/ComponentStateEnum#under-development>
             <https://w3id.org/lmodel/oscal_assessment_plan/ComponentStateEnum#operational>
             <https://w3id.org/lmodel/oscal_assessment_plan/ComponentStateEnum#disposition>
             <https://w3id.org/lmodel/oscal_assessment_plan/ComponentStateEnum#other> ] ;
