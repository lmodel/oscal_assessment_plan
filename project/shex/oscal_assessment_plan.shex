          oscal_catalog:identifier @linkml:String
       ) ;
       rdf:type [ oscal_catalog:DocumentId ] ?
    )
}

<EventTiming> CLOSED {
    (  $<EventTiming_tes> (  <on_date> @<OnDateCondition> ? ;
          <within_date_range> @<WithinDateRange> ? ;
          <at_frequency> @<AtFrequency> ?
       ) ;
       rdf:type [ <EventTiming> ] ?
    )
}

<Facet> CLOSED {
